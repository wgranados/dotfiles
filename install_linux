#!/bin/bash
# Install Git global config and Vim config from this repository (run from repo root
# or any directory — paths are resolved from this script's location).

set -euo pipefail

HERE="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

setup_git_env() {
    git config --global user.email "me@wgma.ca"
    git config --global user.name "William Granados"
    git config --global core.editor "vim"
}

setup_vim_env() {
    rm -rf ~/.vim
    rm -f ~/.vimrc
    cp -a "${HERE}/.vim" "${HOME}/.vim"
    cp -a "${HERE}/.vimrc" "${HOME}/.vimrc"
    mkdir -p "${HOME}/.vim/bundle"
    rm -rf "${HOME}/.vim/bundle/Vundle.vim"
    git clone --depth 1 https://github.com/VundleVim/Vundle.vim.git "${HOME}/.vim/bundle/Vundle.vim"
    rm -rf "${HOME}/.vim/bundle/vim-colors-solarized"
    git clone --depth 1 https://github.com/altercation/vim-colors-solarized.git "${HOME}/.vim/bundle/vim-colors-solarized"
    echo "Vim: open vim and run :PluginInstall to fetch remaining plugins (NERDTree, YouCompleteMe, etc.)."
}

read -r -p "Set up Git and Vim from this dotfiles repo? [y/N] " option
if [[ "${option,,}" != "y" ]]; then
    exit 0
fi

read -r -p "Configure Git (user.name, user.email, core.editor)? [Y/n] " option
if [[ -z "${option}" || "${option,,}" == "y" ]]; then
    setup_git_env
    echo "Git global config updated."
fi

read -r -p "Install Vim config (~/.vim, ~/.vimrc) and clone Vundle + Solarized? [Y/n] " option
if [[ -z "${option}" || "${option,,}" == "y" ]]; then
    setup_vim_env
    echo "Vim layout installed."
fi

echo "Done."
